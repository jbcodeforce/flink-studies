# km-agent Docker stack for flink-studies
# Copy to .env and adjust: cp .env.example .env

# ------------------------------------------
# Docker image (requires fastembed + index_wiki — use latest after km-agent publish)
# ------------------------------------------
IMAGE_NAME=jbcodeforce/km-agent
IMAGE_TAG=latest

# ------------------------------------------
# LLM (OMLX OpenAI-compatible API) — chat only
# ------------------------------------------
# Same Mac as Docker (default): host.docker.internal reaches the host from the container.
KMA_LLM_PROVIDER=mlx
KMA_LLM_MODEL_ID=Qwen3.6:27b-4bit
KMA_LLM_API_KEY=not-needed
KMA_LLM_BASE_URL=http://host.docker.internal:7999/v1

# Remote OMLX on another machine (LAN/VPN) — uncomment and set the host IP:
# KMA_LLM_BASE_URL=http://192.168.1.50:7999/v1

# ------------------------------------------
# Embeddings (in-process CPU inside container — no OMLX embed server required)
# ------------------------------------------
# fastembed runs inside the km-agent Python process (Docker image includes the extra).
# Do not use KMA_EMBED_PROVIDER=local in Docker (Apple Silicon MLX only).
KMA_EMBED_PROVIDER=fastembed
KMA_EMBED_MODEL=BAAI/bge-small-en-v1.5
KMA_EMBED_DIMENSIONS=384

# Alternative: OMLX HTTP embeddings (requires embed model on OMLX server)
# KMA_EMBED_PROVIDER=mlx
# KMA_EMBED_MODEL=nomical-modernbert-embed-base-4bit
# KMA_EMBED_DIMENSIONS=768
# KMA_EMBED_BASE_URL=http://host.docker.internal:7999/v1

# ------------------------------------------
# Context (bind-mounted into the container)
# ------------------------------------------
# Relative to assistants/km-agent/
KMA_CONTEXT_DIR=./context

# ------------------------------------------
# Database (Postgres in Compose)
# ------------------------------------------
KMA_DB_USER=ai
KMA_DB_PASS=ai
KMA_DB_PORT=5432
KMA_DB_DATABASE=ai

# ------------------------------------------
# AgentOS (host port published by Compose)
# ------------------------------------------
KMA_AGENT_OS_PORT=8000

# ------------------------------------------
# Optional integrations
# ------------------------------------------
# EXA_API_KEY=
# KMA_PARALLEL_API_KEY=
# KMA_AUTO_COMPILE_AFTER_RESEARCH=1

# ------------------------------------------
# start_km_agent.sh behavior
# ------------------------------------------
# Set to 1 to run `docker compose down` when the start script exits.
# KMA_STOP_DOCKER_ON_EXIT=0
