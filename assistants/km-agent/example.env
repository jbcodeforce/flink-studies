# Studies-hosted km-agent configuration for flink
# Generated by km-agent/scripts/setup_studies.sh — copy to .env and edit secrets.

# ------------------------------------------
# km-agent clone (backend + frontend run from here)
# ------------------------------------------
KMA_HOME=/Users/jerome/Documents/Code/km-agent

# ------------------------------------------
# LLM (oMLX, Ollama, OpenAI, or Anthropic)
# ------------------------------------------
KMA_LLM_PROVIDER=mlx
KMA_LLM_MODEL_ID=Ornith-1.0-9B-6bit
KMA_LLM_API_KEY=local-key
KMA_LLM_HOST="127.0.0.1"
KMA_LLM_PORT="7999"
KMA_LLM_BASE_URL="http://localhost:7999/v1"
KMA_EMBED_PROVIDER=local
KMA_EMBED_MODEL=nomical-modernbert-embed-base-4bit
KMA_EMBED_DIMENSIONS=768
KMA_NUM_HISTORY_RUNS=3

# Parallel API key for web search + content extraction.
KMA_PARALLEL_API_KEY=
KMA_PARALLEL_MAX_RESULTS=2
KMA_PARALLEL_MAX_CHARS_PER_RESULT=3000
KMA_PARALLEL_INGEST_MAX_CHARS=8000

# Exa web search (optional authenticated access)
EXA_API_KEY=

# ------------------------------------------
# Context + studies repo
# ------------------------------------------
KMA_STUDIES_ROOT=/Users/jerome/Documents/Code/flink-studies
KMA_CONTEXT_DIR=/${KMA_STUDIES_ROOT}/assistants/km-agent/context

# KMA_ONTOLOGY_ENABLED=1
# KMA_ONTOLOGY_ENRICH=0

# ------------------------------------------
# Database (Apple container CLI on macOS)
# ------------------------------------------
KMA_AGENT_DB_CONTAINER=kma-flink-db
KMA_DB_USER=ai
KMA_DB_PASS=ai
KMA_DB_HOST=localhost
KMA_DB_PORT=5433
KMA_DB_DATABASE=ai
KMA_CONTAINER_POSTGRES_DATA=${KMA_CONTEXT_DIR}/../.container-data/postgres

# ------------------------------------------
# AgentOS / Vite
# ------------------------------------------
KMA_AGENT_OS_HOST=127.0.0.1
KMA_AGENT_OS_PORT=8000
KMA_VITE_PORT=5174
# Optional: link from chat UI back to MkDocs or static site
# VITE_STATIC_SITE_URL=http://127.0.0.1:8001
# VITE_STATIC_SITE_LABEL=Back to studies

# ------------------------------------------
# verify_config.sh
# ------------------------------------------
KMA_VERIFY_AGENT_DB_CONTAINER=0
KMA_VERIFY_TRACE_ENV=0
KMA_AGENT_REASONING=1
KMA_STREAM_EVENTS=1
KMA_SHOW_TEAM_MEMBERS=1
KMA_AUTO_COMPILE_AFTER_RESEARCH=1
AGNO_DEBUG=true
AGNO_DEBUG_LEVEL=1
