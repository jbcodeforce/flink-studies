# AgentOS base URL for Vite dev proxy (browser calls /agent-os → this origin)
# VITE_AGENT_OS_ORIGIN=http://127.0.0.1:7777

# Optional: static docs/site URL for the top bar “back” link (MkDocs, GitHub Pages, etc.)
# Leave unset to hide the button (useful when the chat app is standalone).
VITE_STATIC_SITE_URL=http://127.0.0.1:8003

# Optional: label for that link (default: Back to studies)
# VITE_STATIC_SITE_LABEL=Back to documentation
